{
  "name": "@cvkit/cli",
  "version": "0.1.0",
  "description": "cvkit — Academic CV management CLI",
  "type": "module",
  "bin": {
    "cvkit": "./dist/cli.js"
  },
  "files": ["dist"],
  "scripts": {
